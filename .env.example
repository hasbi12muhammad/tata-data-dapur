# ── Per-deployment env (one client = one deployment) ──────────────────────
# Copy to the client's Cloudflare Pages project env. The codebase is identical
# across all clients; ONLY these values differ per client.

# Client's own Supabase project (their isolated database) ------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_CLIENT_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_CLIENT_ANON_KEY

# Tenant branding ----------------------------------------------------------
NEXT_PUBLIC_TENANT_NAME=Nama Bisnis Klien
NEXT_PUBLIC_TENANT_PLAN=base

# Feature packages ---------------------------------------------------------
# Add-on features to switch ON (comma separated). Core features are on by
# default. Available add-ons: kasir
NEXT_PUBLIC_ENABLED_FEATURES=

# Core features to switch OFF for this client (comma separated). Example:
# hide the Produk/Recipes module → NEXT_PUBLIC_DISABLED_FEATURES=recipes
NEXT_PUBLIC_DISABLED_FEATURES=
